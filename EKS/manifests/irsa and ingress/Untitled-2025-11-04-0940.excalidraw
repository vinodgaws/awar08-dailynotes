    {
      "id": "drIRJ-rJ2VRfywiCymNmi",
      "type": "text",
      "x": 769.7488124200564,
      "y": 5101.460755235969,
      "width": 1227.599365234375,
      "height": 405,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b58",
      "roundness": null,
      "seed": 1622813845,
      "version": 496,
      "versionNonce": 2043541115,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780634907725,
      "link": null,
      "locked": false,
      "text": "\nInfrastructure : Servers, network, db, security, monitoring \n\nWe need to purchase as upfront : Capital Expenditure : CAPEX. \n\nLess With cloud : Operational Expenditure : OPEX\n\nPay-as-you-go : Pay for the resources you actually use. \nServer - 1 day -> you pay for 1 day usage.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nInfrastructure : Servers, network, db, security, monitoring \n\nWe need to purchase as upfront : Capital Expenditure : CAPEX. \n\nLess With cloud : Operational Expenditure : OPEX\n\nPay-as-you-go : Pay for the resources you actually use. \nServer - 1 day -> you pay for 1 day usage.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "E1MfevgcYompufbk0R4-O",
      "type": "text",
      "x": 725.0125035958572,
      "y": 5678.17055289488,
      "width": 1524.59912109375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#e03131",
