      "roundness": null,
      "seed": 1843152827,
      "version": 318,
      "versionNonce": 1924510133,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780634949238,
      "link": null,
      "locked": false,
      "text": "SDLC : Software Development Life Cycle \n\n\nWaterfall methodology : Taking requirements at starting stage and developing \napplication and delivering final product. ",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SDLC : Software Development Life Cycle \n\n\nWaterfall methodology : Taking requirements at starting stage and developing \napplication and delivering final product. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
